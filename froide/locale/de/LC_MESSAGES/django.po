"\n"
"%(action_url)s\n"
"\n"

#: froide/account/templates/account/emails/confirm_action.txt:1
#, python-format
msgid ""
"Hello %(name)s,\n"
"\n"
"are you trying to send a request on %(site_name)s with the subject "
"“%(title)s”?\n"
"\n"
"If so, please click the following link to continue\n"
"\n"
"%(action_url)s\n"
"\n"
"If you are not trying to send this request, please ignore this email. No "
"further action is required on your part."
msgstr ""
"Hallo %(name)s,\n"
"\n"
"haben Sie versucht eine Anfrage auf %(site_name)s namens „%(title)s“ zu "
"versenden?\n"
"\n"
"Falls ja, klicken Sie zum Bestätigen bitte den folgenden Link:\n"
"\n"
"%(action_url)s\n"
"\n"
"Falls Sie diese Anfrage nicht stellen wollen, ignorieren Sie bitte diese E-"
"Mail. Sie müssen dann nichts weiter tun."

