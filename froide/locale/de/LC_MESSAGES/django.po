#: froide/account/templates/account/emails/change_email.txt:1
#, python-format
msgid ""
"Hello %(name)s,\n"
"\n"
"This is an email from %(site_name)s to confirm your new email address.\n"
"Please visit the link below:\n"
"\n"
"%(action_url)s\n"
"\n"
